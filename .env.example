# Copy to `.env` and fill in. All three are OPTIONAL — the app runs without them
# (localStorage mode, no scraping). Fill them in to unlock cloud sync + scraping.

# --- Supabase (cloud storage) ---
# From Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Cloudflare Worker scraper ---
# Printed by `wrangler deploy` — e.g. https://crete-scraper.your-account.workers.dev
VITE_SCRAPER_URL=

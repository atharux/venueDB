# Copy to `.env` and fill in. All three VITE_ vars are OPTIONAL — the app runs
# without them (localStorage mode, no scraping). Fill them in to unlock cloud
# sync and scraping.

# --- Supabase (cloud storage) ---
# From Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Cloudflare Worker scraper ---
# Printed by `wrangler deploy` — e.g. https://venue-scraper.your-account.workers.dev
VITE_SCRAPER_URL=

# ---------------------------------------------------------------------------
# WORKER-ONLY variables — set these in the Cloudflare Worker environment
# (via wrangler.toml [vars] or the dashboard). Do NOT put them here or in any
# file that is bundled into the frontend; they will be exposed in the JS bundle.
# ---------------------------------------------------------------------------
# OPENROUTER_API_KEY=        # LLM routing for contact extraction
# SCRAPER_MODEL=             # Which model to use, e.g. openrouter/auto
# GOOGLE_MAPS_API_KEY=       # Places API — see ToS warning in Discover → Settings
#                              before activating: storing Places data in a DB
#                              violates Google Maps Platform Terms of Service.
